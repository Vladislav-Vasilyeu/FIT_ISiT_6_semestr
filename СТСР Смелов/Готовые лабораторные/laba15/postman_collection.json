    },
    {
      "name": "Errors",
      "item": [
        {
          "name": "GET unknown route",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/unknown"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Route not found error is returned', function () {",
                  "  pm.expect(pm.response.json().error).to.eql('Route not found');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/faculties invalid JSON",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ invalid json"
            },
            "url": "{{baseUrl}}/api/faculties"
          },
          "event": [
            {
              "listen": "test",
              "script": {
