                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.eql('Deleted');",
                  "  pm.expect(json.faculty).to.eql(pm.collectionVariables.get('facultyCode'));",
                  "});"
                ]
              }
            }
