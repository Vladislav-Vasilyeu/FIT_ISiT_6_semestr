{
  "info": {
    "name": "Laba15 MongoDB API checks",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "facultyCode",
      "value": "TEST_FAC"
    },
    {
      "key": "pulpitCode",
      "value": "TEST_PULP"
    }
  ],
  "item": [
    {
      "name": "Faculties",
      "item": [
        {
          "name": "GET /api/faculties",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/faculties"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/faculties",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"faculty\": \"{{facultyCode}}\",\n  \"faculty_name\": \"Test faculty\"\n}"
            },
            "url": "{{baseUrl}}/api/faculties"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Created faculty is returned', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.faculty).to.eql(pm.collectionVariables.get('facultyCode'));",
                  "  pm.expect(json.faculty_name).to.eql('Test faculty');",
                  "  pm.expect(json._id).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/faculties contains created faculty",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/faculties"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Created faculty exists in list', function () {",
                  "  const list = pm.response.json();",
                  "  const facultyCode = pm.collectionVariables.get('facultyCode');",
                  "  pm.expect(list.some(item => item.faculty === facultyCode)).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT /api/faculties",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"faculty\": \"{{facultyCode}}\",\n  \"faculty_name\": \"Updated test faculty\"\n}"
            },
            "url": "{{baseUrl}}/api/faculties"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Update message is returned', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.eql('Updated');",
                  "  pm.expect(json.faculty_name).to.eql('Updated test faculty');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT /api/faculties not found",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"faculty\": \"NO_SUCH_FAC\",\n  \"faculty_name\": \"Missing faculty\"\n}"
            },
            "url": "{{baseUrl}}/api/faculties"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Error message is returned', function () {",
                  "  pm.expect(pm.response.json().error).to.eql('Faculty not found');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
