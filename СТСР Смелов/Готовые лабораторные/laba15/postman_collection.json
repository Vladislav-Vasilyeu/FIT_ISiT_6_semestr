                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT /api/pulpits not found",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pulpit\": \"NO_SUCH_PULP\",\n  \"pulpit_name\": \"Missing pulpit\",\n  \"faculty\": \"NO_SUCH_FAC\"\n}"
            },
            "url": "{{baseUrl}}/api/pulpits"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Error message is returned', function () {",
                  "  pm.expect(pm.response.json().error).to.eql('Pulpit not found');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Cleanup",
      "item": [
        {
          "name": "DELETE /api/pulpits/:pulpit",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/pulpits/{{pulpitCode}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Delete message is returned', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.eql('Deleted');",
                  "  pm.expect(json.pulpit).to.eql(pm.collectionVariables.get('pulpitCode'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE /api/faculties/:faculty",
          "request": {
            "method": "DELETE",
