            "body": {
              "mode": "raw",
              "raw": "{\n  \"pulpit\": \"{{pulpitCode}}\",\n  \"pulpit_name\": \"Updated test pulpit\",\n  \"faculty\": \"{{facultyCode}}\"\n}"
            },
            "url": "{{baseUrl}}/api/pulpits"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
