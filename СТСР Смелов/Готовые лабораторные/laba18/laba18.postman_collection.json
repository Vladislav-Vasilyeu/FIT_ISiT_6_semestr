      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('returns HTML', function () {",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('text/html');",
              "});"
